{
  "name": "joshua/5250-to-web-ui",
  "description": "Toolkit for converting IBM i 5250 green-screen applications to modern web UIs",
  "version": "1.0.0",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "php bin/analyze-5250.php --help"
  }
}
